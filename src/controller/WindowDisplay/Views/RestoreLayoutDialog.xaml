<Window x:Class="WindowDisplay.Views.RestoreLayoutDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore Layout" Width="500" Height="420" WindowStartupLocation="CenterOwner">
  <DockPanel Margin="24"><StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}"/><Button Content="Restore" Click="Restore_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="Restore a saved layout" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="Displays will be recreated to match the saved layout." Foreground="{DynamicResource SubtleTextBrush}" Margin="0,5,0,14"/></StackPanel><ListBox x:Name="Layouts" DisplayMemberPath="Name"/></DockPanel>
</Window>
