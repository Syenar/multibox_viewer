<Window x:Class="WindowDisplay.Views.ResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Resolution" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <StackPanel Margin="24">
    <TextBlock Text="Choose a resolution" FontSize="20" FontWeight="SemiBold"/>
    <ListBox x:Name="PresetList" SelectedIndex="0" Margin="0,14,0,0" BorderThickness="0">
      <ListBoxItem Tag="1280,720,60" Content="1280 × 720 · 60 Hz"/>
      <ListBoxItem Tag="1920,1080,60" Content="1920 × 1080 · 60 Hz"/>
      <ListBoxItem Tag="2560,1440,60" Content="2560 × 1440 · 60 Hz"/>
      <ListBoxItem Tag="3840,2160,60" Content="3840 × 2160 · 60 Hz"/>
    </ListBox>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
      <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}"/>
      <Button Content="Apply" Click="Apply_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
    </StackPanel>
  </StackPanel>
</Window>
