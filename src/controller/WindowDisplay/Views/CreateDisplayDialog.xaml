<Window x:Class="WindowDisplay.Views.CreateDisplayDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Display" Width="520" SizeToContent="Height" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <StackPanel Margin="28">
    <TextBlock Text="Choose a display preset" FontSize="22" FontWeight="SemiBold"/>
    <TextBlock Text="Recommended is selected for a balanced, reliable workspace." Foreground="{DynamicResource SubtleTextBrush}" Margin="0,5,0,18"/>
    <ListBox x:Name="PresetList" SelectedIndex="0" BorderThickness="0" SelectionChanged="PresetList_SelectionChanged">
      <ListBoxItem Tag="1920,1080,60"><StackPanel><TextBlock Text="Recommended" FontWeight="SemiBold"/><TextBlock Text="1920 × 1080 · 60 Hz" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></ListBoxItem>
      <ListBoxItem Tag="1280,720,60"><StackPanel><TextBlock Text="Compact" FontWeight="SemiBold"/><TextBlock Text="1280 × 720 · 60 Hz" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></ListBoxItem>
      <ListBoxItem Tag="2560,1440,60"><StackPanel><TextBlock Text="Large" FontWeight="SemiBold"/><TextBlock Text="2560 × 1440 · 60 Hz" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></ListBoxItem>
      <ListBoxItem Tag="custom"><StackPanel><TextBlock Text="Custom" FontWeight="SemiBold"/><TextBlock Text="Enter width, height, and refresh rate" Foreground="{DynamicResource SubtleTextBrush}"/></StackPanel></ListBoxItem>
    </ListBox>
    <Grid x:Name="CustomPanel" Visibility="Collapsed" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Width" Foreground="{DynamicResource SubtleTextBrush}"/>
        <TextBox x:Name="CustomWidth" Text="1920" Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="2">
        <TextBlock Text="Height" Foreground="{DynamicResource SubtleTextBrush}"/>
        <TextBox x:Name="CustomHeight" Text="1080" Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="4">
        <TextBlock Text="Hz" Foreground="{DynamicResource SubtleTextBrush}"/>
        <TextBox x:Name="CustomRefresh" Text="60" Margin="0,4,0,0"/>
      </StackPanel>
    </Grid>
    <CheckBox x:Name="OpenViewer" Content="Open viewer after creation" IsChecked="True" Margin="0,16,0,20"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}"/>
      <Button Content="Create" Click="Create_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
    </StackPanel>
  </StackPanel>
</Window>
