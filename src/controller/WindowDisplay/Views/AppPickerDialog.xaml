<Window x:Class="WindowDisplay.Views.AppPickerDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move App" Width="560" Height="520" WindowStartupLocation="CenterOwner">
  <DockPanel Margin="24">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button Content="Browse" Click="Browse_Click" Style="{StaticResource SecondaryButton}"/><Button Content="Move" Click="Move_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel>
    <StackPanel DockPanel.Dock="Top"><TextBlock Text="Move an app to this display" FontSize="20" FontWeight="SemiBold"/><TextBox x:Name="SearchBox" TextChanged="Search_TextChanged" Margin="0,14,0,12" ToolTip="Search open apps"/></StackPanel>
    <ListBox x:Name="Apps" DisplayMemberPath="DisplayName"/>
  </DockPanel>
</Window>
