<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="CanvasColor">#FFF4F7F9</Color>
  <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
  <Color x:Key="SurfaceMutedColor">#FFE8EEF2</Color>
  <Color x:Key="TextColor">#FF17222C</Color>
  <Color x:Key="SubtleTextColor">#FF5B6874</Color>
  <Color x:Key="BorderColor">#FFD8E0E6</Color>
  <Color x:Key="AccentColor">#FF176B93</Color>
  <Color x:Key="AccentHoverColor">#FF0E587B</Color>
  <Color x:Key="SuccessColor">#FF247A5A</Color>
  <Color x:Key="DangerColor">#FFC24842</Color>
  <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource SubtleTextColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

  <Style TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource CanvasBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
  </Style>
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="20"/>
  </Style>
  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="16,9"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style TargetType="Button">
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="8,5"/>
  </Style>
  <Style TargetType="TextBox">
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
  </Style>
</ResourceDictionary>
